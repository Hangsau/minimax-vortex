---
/**
 * periodization/index.astro — 訓練週期化
 *
 * 設計依據（per Bompa Periodization 6th ed.）：
 * - 6 節：三大階段 / 年度計畫類型 / 中觀微觀 / 賽前減量 / 能量分區 / 停練流失
 * - 錨點導航（不是 master-detail，是長頁面 + 章節錨點）
 * - 表格用原生 HTML（不用 JS）
 */
import Base from '../../layouts/Base.astro';
import MiniLadder from '../../components/MiniLadder.astro';

const sections = [
  { id: 'three-phases', no: '壹', title: '三大階段', tag: 'Three Macro-Phases' },
  { id: 'annual-types', no: '貳', title: '年度計畫類型', tag: 'Annual Plan Types' },
  { id: 'meso-micro', no: '參', title: '中觀與微觀週期', tag: 'Meso & Micro Cycles' },
  { id: 'taper', no: '肆', title: '賽前減量達峰', tag: 'Taper & Peaking' },
  { id: 'energy-zones', no: '伍', title: '能量系統分區', tag: 'Energy System Zones' },
  { id: 'detraining', no: '陸', title: '停練流失', tag: 'Detraining & Reversibility' },
];
---

<Base
  title="訓練週期化"
  description="三大階段、年度計畫類型、中觀微觀週期、賽前減量達峰、能量系統分區、停練流失。源自 Bompa Periodization 6th ed.。"
>

  <!-- ═══ Hero ═══ -->
  <section class="hero">
    <p class="eyebrow">Periodization · Bompa 6th ed.</p>
    <h1 class="hero__title">訓練週期化</h1>
    <p class="hero__lead">
      週期化不是「把課表排漂亮」——是「<strong>何時把什麼素質推到極限、何時回收</strong>」的時間管理。
      長程 → 中程 → 短程 → 一個 workout，層層嵌套。
    </p>
    <MiniLadder levels={['L3', 'L4', 'L5', 'L6']} label="主要在 L3–L6 競技端" />
  </section>

  <!-- ═══ 錨點導航 ═══ -->
  <nav class="anchor-nav" aria-label="章節錨點導航">
    <p class="anchor-nav__cap">目錄</p>
    <ol class="anchor-nav__list">
      {sections.map((s) => (
        <li>
          <a href={`#${s.id}`}>
            <span class="anchor-nav__no">{s.no}</span>
            <span class="anchor-nav__title">{s.title}</span>
            <span class="anchor-nav__tag">{s.tag}</span>
          </a>
        </li>
      ))}
    </ol>
  </nav>

  <!-- ════════════════════════════════════════════════════════════
       壹、三大階段
       ════════════════════════════════════════════════════════════ -->
  <section class="ch" id="three-phases">
    <header class="ch__head">
      <p class="eyebrow ch__no">壹</p>
      <h2 class="ch__title">三大階段</h2>
      <p class="ch__tag">Three Macro-Phases</p>
    </header>

    <p class="ch__lead">
      Bompa 的經典三分：準備期（Preparatory）→ 競賽期（Competitive）→ 過渡期（Transition）。
      每一段都有清楚的「生理適應目標」與「訓練量配置」。
    </p>

    <table class="data-table">
      <thead>
        <tr>
          <th>階段</th>
          <th>英文</th>
          <th>主要目標</th>
          <th>典型週數</th>
          <th>訓練量</th>
          <th>訓練強度</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td><strong>準備期</strong></td>
          <td>Preparatory</td>
          <td>建立體能地基（耐力、肌力、柔軟度）</td>
          <td>8 – 24 週</td>
          <td>高（往上加）</td>
          <td>中低（先廣後深）</td>
        </tr>
        <tr>
          <td><strong>競賽期</strong></td>
          <td>Competitive</td>
          <td>把準備期累積的體能轉成比賽表現</td>
          <td>4 – 16 週</td>
          <td>中（逐週降）</td>
          <td>高（衝刺 + 比賽）</td>
        </tr>
        <tr>
          <td><strong>過渡期</strong></td>
          <td>Transition</td>
          <td>主動恢復、心理充電、跨季轉銜</td>
          <td>2 – 6 週</td>
          <td>低（降到 50%–70%）</td>
          <td>低（多元休閒）</td>
        </tr>
      </tbody>
    </table>

    <details class="note">
      <summary>註：為什麼訓練量在競賽期要降？</summary>
      <p>
        訓練量（volume）與訓練強度（intensity）是兩條獨立曲線——累積體能靠「量」，
        衝刺表現靠「強度」。比賽前需要「高強度低總量」，讓神經系統與肌肉纖維完全恢復，
        卻不流失體能。這就是為什麼巔峰期量往下掉、強度往上提。
      </p>
    </details>
  </section>

  <!-- ════════════════════════════════════════════════════════════
       貳、年度計畫類型
       ════════════════════════════════════════════════════════════ -->
  <section class="ch" id="annual-types">
    <header class="ch__head">
      <p class="eyebrow ch__no">貳</p>
      <h2 class="ch__title">年度計畫類型</h2>
      <p class="ch__tag">Annual Plan Types</p>
    </header>

    <p class="ch__lead">
      不同競賽密度對應不同的「年架構」——把多個「準備 → 競賽 → 過渡」三段組合成一年的形狀。
    </p>

    <table class="data-table">
      <thead>
        <tr>
          <th>類型</th>
          <th>結構</th>
          <th>巔峰數/年</th>
          <th>適用對象</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td><strong>單週期</strong></td>
          <td>1 × 準備 → 競賽 → 過渡</td>
          <td>1</td>
          <td>業餘、初學、青少年第一年</td>
        </tr>
        <tr>
          <td><strong>雙週期</strong></td>
          <td>2 × 三段</td>
          <td>2</td>
          <td>俱樂部選手、大學隊</td>
        </tr>
        <tr>
          <td><strong>三週期</strong></td>
          <td>3 × 三段</td>
          <td>3</td>
          <td>高級俱樂部、青少年精英</td>
        </tr>
        <tr>
          <td><strong>多週期</strong></td>
          <td>3+ × 三段 + 微型峰</td>
          <td>3 + 短期峰</td>
          <td>準職業、職業、奧運週期</td>
        </tr>
      </tbody>
    </table>

    <details class="note">
      <summary>為什麼大多數頂尖選手是「多週期」？</summary>
      <p>
        現代游泳賽季超過 10 個月，若一年只衝一次，會有 8 個月在等。
        多週期 = 3 個主峰 + 多個微型峰，量累積在主峰前的準備期，
        微型峰（2–3 週的減量達峰）穿插在競賽期內應付中程賽事。
      </p>
    </details>
  </section>

  <!-- ════════════════════════════════════════════════════════════
       參、中觀與微觀週期
       ════════════════════════════════════════════════════════════ -->
  <section class="ch" id="meso-micro">
    <header class="ch__head">
      <p class="eyebrow ch__no">參</p>
      <h2 class="ch__title">中觀與微觀週期</h2>
      <p class="ch__tag">Meso &amp; Micro Cycles</p>
    </header>

    <p class="ch__lead">
      「一年怎麼切」是巨觀，「每 3–6 週怎麼切」是中觀，「每週 7 天怎麼排」是微觀。
      三者層層嵌套，缺一不可。
    </p>

    <h3 class="ch__sub">中觀週期（Meso-Cycle）：3 – 6 週</h3>
    <table class="data-table">
      <thead>
        <tr>
          <th>週</th>
          <th>角色</th>
          <th>主要工作</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td>第 1 週</td>
          <td>載入</td>
          <td>高量、中低強度，引入新動作 / 新器材</td>
        </tr>
        <tr>
          <td>第 2 週</td>
          <td>發展</td>
          <td>持續加量、特定素質（VO2max、肌力）重點刺激</td>
        </tr>
        <tr>
          <td>第 3 週</td>
          <td>巔峰</td>
          <td>量達到本週期頂、強度跟上、單次訓練達到最高負擔</td>
        </tr>
        <tr>
          <td>第 4 週</td>
          <td>減量 / 恢復</td>
          <td>量降至 60%–70%、強度維持、神經系統恢復</td>
        </tr>
      </tbody>
    </table>

    <h3 class="ch__sub">微觀週期（Micro-Cycle）：7 – 14 天</h3>
    <table class="data-table">
      <thead>
        <tr>
          <th>天</th>
          <th>角色</th>
          <th>典型內容</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td>週一</td>
          <td>重點刺激</td>
          <td>高強度（VO2max、速度、爆發力）</td>
        </tr>
        <tr>
          <td>週二</td>
          <td>恢復 / 技術</td>
          <td>低強度、純技術、Drill</td>
        </tr>
        <tr>
          <td>週三</td>
          <td>重點刺激</td>
          <td>高強度（肌力 + 耐力）</td>
        </tr>
        <tr>
          <td>週四</td>
          <td>恢復</td>
          <td>中等強度、輕鬆游</td>
        </tr>
        <tr>
          <td>週五</td>
          <td>重點刺激</td>
          <td>比賽模擬 / 計時 / 配速</td>
        </tr>
        <tr>
          <td>週六</td>
          <td>中等量</td>
          <td>穩定配速、技術細修</td>
        </tr>
        <tr>
          <td>週日</td>
          <td>主動恢復</td>
          <td>輕鬆長游、放鬆、不衝強度</td>
        </tr>
      </tbody>
    </table>
  </section>

  <!-- ════════════════════════════════════════════════════════════
       肆、賽前減量達峰
       ════════════════════════════════════════════════════════════ -->
  <section class="ch" id="taper">
    <header class="ch__head">
      <p class="eyebrow ch__no">肆</p>
      <h2 class="ch__title">賽前減量達峰</h2>
      <p class="ch__tag">Taper &amp; Peaking</p>
    </header>

    <p class="ch__lead">
      比賽前 7 – 21 天，刻意把訓練量往下掉、強度維持，達到「生理飽和 + 神經新鮮」的巔峰狀態。
      減量過短 → 還疲勞；減量過長 → 流失體能。
    </p>

    <table class="data-table">
      <thead>
        <tr>
          <th>項目</th>
          <th>傳統減量（step）</th>
          <th>線性減量（linear）</th>
          <th>指數減量（exponential）</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td><strong>時間長度</strong></td>
          <td>14 – 21 天</td>
          <td>14 – 21 天</td>
          <td>7 – 14 天</td>
        </tr>
        <tr>
          <td><strong>量下降方式</strong></td>
          <td>階梯式（一次掉 30%–40%）</td>
          <td>線性（每天等量下降）</td>
          <td>指數（前期掉得快，後面趨緩）</td>
        </tr>
        <tr>
          <td><strong>強度</strong></td>
          <td>維持</td>
          <td>維持</td>
          <td>維持甚至微升</td>
        </tr>
        <tr>
          <td><strong>頻率</strong></td>
          <td>維持</td>
          <td>略降</td>
          <td>略降</td>
        </tr>
        <tr>
          <td><strong>效果</strong></td>
          <td>有效但容易遲滯</td>
          <td>穩定改善</td>
          <td>近年研究推薦，表現提升最穩</td>
        </tr>
      </tbody>
    </table>

    <details class="note">
      <summary>為什麼減量期間要保留少量高速？</summary>
      <p>
        完全停止高速會讓神經系統「忘記」高速動作模式。
        短而快的高速衝刺（20–30 秒、全力、每組恢復完整）保留「記得怎麼快」，
        同時不累積疲勞——這是「減量不減強」的具體實踐。
      </p>
    </details>
  </section>

  <!-- ════════════════════════════════════════════════════════════
       伍、能量系統分區
       ════════════════════════════════════════════════════════════ -->
  <section class="ch" id="energy-zones">
    <header class="ch__head">
      <p class="eyebrow ch__no">伍</p>
      <h2 class="ch__title">能量系統分區</h2>
          <p class="ch__tag">Energy System Zones</p>
    </header>

    <p class="ch__lead">
      游泳的「有氧 vs 無氧」不是二元對立——ATP-PCr、糖酵解、有氧三系統是連續光譜，
      不同配速下主導系統不同。Maglischo 五區分法是業界最常用的框架。
    </p>

    <table class="data-table">
      <thead>
        <tr>
          <th>區</th>
          <th>名稱</th>
          <th>主要能量系統</th>
          <th>持續時間</th>
          <th>血乳酸</th>
          <th>% VO2max</th>
          <th>典型訓練</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td>1</td>
          <td>恢復 / 極輕</td>
          <td>純有氧</td>
          <td>&gt; 30 分</td>
          <td>&lt; 2 mmol/L</td>
          <td>&lt; 60%</td>
          <td>熱身、放鬆、主動恢復</td>
        </tr>
        <tr>
          <td>2</td>
          <td>有氧基礎</td>
          <td>有氧為主</td>
          <td>20 – 60 分</td>
          <td>2 – 4</td>
          <td>60% – 75%</td>
          <td>長游、穩定配速、TS（Threshold Sweet Spot）</td>
        </tr>
        <tr>
          <td>3</td>
          <td>有氧臨界</td>
          <td>有氧 + 糖酵解混合</td>
          <td>8 – 30 分</td>
          <td>4 – 8</td>
          <td>75% – 85%</td>
          <td>巡航間歇、Anaerobic Threshold（AT）</td>
        </tr>
        <tr>
          <td>4</td>
          <td>無氧臨界</td>
          <td>糖酵解為主</td>
          <td>2 – 8 分</td>
          <td>8 – 12</td>
          <td>85% – 95%</td>
          <td>VO2max 間歇、200/400m 衝刺</td>
        </tr>
        <tr>
          <td>5</td>
          <td>神經肌肉 / 速度</td>
          <td>ATP-PCr</td>
          <td>&lt; 90 秒</td>
          <td>&gt; 12</td>
          <td>95% – 100%</td>
          <td>短衝、起跳、出發、划手節奏</td>
        </tr>
      </tbody>
    </table>

    <details class="note">
      <summary>怎麼把分區配進週期？</summary>
      <p>
        準備期以區 1–2 為主（打地基），中段加入區 3 拉高有氧上限，
        競賽期大量區 4（VO2max）衝擊無氧容量，區 5 全年都保留（神經肌肉保鮮）。
        減量期區 1 為主，區 5 維持、區 4 略降。
      </p>
    </details>
  </section>

  <!-- ════════════════════════════════════════════════════════════
       陸、停練流失
       ════════════════════════════════════════════════════════════ -->
  <section class="ch" id="detraining">
    <header class="ch__head">
      <p class="eyebrow ch__no">陸</p>
      <h2 class="ch__title">停練流失</h2>
      <p class="ch__tag">Detraining &amp; Reversibility</p>
    </header>

    <p class="ch__lead">
      停練（或大幅減量）後，不同素質的流失速度差異極大——理解這個差異決定
      「傷病休養可以休多久」「過渡期怎麼安排」。
    </p>

    <table class="data-table">
      <thead>
        <tr>
          <th>素質</th>
          <th>明顯流失起點</th>
          <th>半衰期（約略）</th>
          <th>備註</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td>VO2max（最大攝氧量）</td>
          <td>2 – 3 週</td>
          <td>~ 4 週</td>
          <td>有氧容量流失快；恢復也快（4 – 6 週可回原值）</td>
        </tr>
        <tr>
          <td>肌力</td>
          <td>3 – 4 週</td>
          <td>~ 6 週</td>
          <td>神經性肌力先掉，肌肉量流失較慢</td>
        </tr>
        <tr>
          <td>肌肉量</td>
          <td>4 – 6 週</td>
          <td>~ 8 週</td>
          <td>明顯流失需要長時間</td>
        </tr>
        <tr>
          <td>速度 / 神經肌肉</td>
          <td>1 – 2 週</td>
          <td>~ 3 週</td>
          <td>流失最快；高強度衝刺 1 週沒做就掉</td>
        </tr>
        <tr>
          <td>柔軟度</td>
          <td>1 – 2 週</td>
          <td>~ 2 週</td>
          <td>流失最快</td>
        </tr>
        <tr>
          <td>技術 / 動作模式</td>
          <td>4 – 6 週</td>
          <td>~ 12 週</td>
          <td>流失最慢；但要完全恢復感知自動化需 3 – 6 個月</td>
        </tr>
      </tbody>
    </table>

    <details class="note">
      <summary>實務啟示</summary>
      <ul>
        <li><strong>短休（≤ 1 週）：</strong>速度優先保留——每週至少 1 次高速衝刺（區 5）</li>
        <li><strong>中休（2 – 4 週）：</strong>過渡期——量降到 50%，但每週 2 – 3 次區 4 + 區 5 衝刺</li>
        <li><strong>長休（4 週+）：</strong>傷病或大休息——完全停 2 週內、之後要 6 – 8 週才能回到巔峰</li>
        <li><strong>完全停練的底線：</strong>不要超過 4 週——再久，VO2max 流失會到要 3 個月才回得來的程度</li>
      </ul>
    </details>
  </section>

  <style>
    /* ═══ Hero ═══ */
    .hero {
      padding: var(--space-6) 0 var(--space-5);
      border-bottom: 2px solid var(--color-rule-strong);
    }
    .hero__title {
      font-family: var(--font-serif);
      font-weight: 700;
      font-size: clamp(var(--type-2xl), 5vw, var(--type-3xl));
      line-height: 1.1;
      margin: var(--space-2) 0 var(--space-3);
    }
    .hero__lead {
      font-family: var(--font-serif);
      font-size: var(--type-md);
      line-height: var(--line-body-cjk);
      color: var(--color-ink-soft);
      max-width: var(--measure-narrow);
      margin-bottom: var(--space-4);
    }
    .hero :global(.mini-ladder) { margin-top: var(--space-3); }

    /* ═══ Anchor nav ═══ */
    .anchor-nav {
      margin: var(--space-5) 0 var(--space-6);
      padding: var(--space-3);
      border: 1px solid var(--color-rule);
      background: var(--color-bg-soft);
    }
    .anchor-nav__cap {
      font-family: var(--font-mono);
      font-size: var(--type-xs);
      letter-spacing: var(--tracking-eyebrow);
      text-transform: uppercase;
      color: var(--color-sub);
      margin: 0 0 var(--space-2);
    }
    .anchor-nav__list {
      list-style: none;
      margin: 0;
      padding: 0;
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
      gap: var(--space-1);
    }
    .anchor-nav__list a {
      display: flex;
      align-items: baseline;
      gap: var(--space-2);
      padding: var(--space-1) var(--space-2);
      text-decoration: none;
      color: var(--color-ink);
      border-left: 2px solid transparent;
      transition: border-color var(--duration-short) var(--ease-standard),
                  background-color var(--duration-short) var(--ease-standard);
    }
    .anchor-nav__list a:hover {
      border-left-color: var(--color-accent);
      background: var(--color-bg-elev);
    }
    .anchor-nav__no {
      font-family: var(--font-mono);
      font-size: var(--type-sm);
      color: var(--color-accent);
      flex: 0 0 28px;
    }
    .anchor-nav__title {
      font-family: var(--font-serif);
      font-size: var(--type-sm);
      font-weight: 600;
      flex: 1;
    }
    .anchor-nav__tag {
      font-family: var(--font-mono);
      font-size: var(--type-tiny);
      color: var(--color-sub);
      letter-spacing: var(--tracking-mono);
    }

    /* ═══ Chapter ═══ */
    .ch {
      margin-top: var(--space-7);
      padding-top: var(--space-4);
      border-top: 2px solid var(--color-rule-strong);
      scroll-margin-top: var(--space-3);
    }
    .ch__head {
      display: flex;
      align-items: baseline;
      gap: var(--space-3);
      flex-wrap: wrap;
      margin-bottom: var(--space-3);
    }
    .ch__no {
      margin: 0;
    }
    .ch__title {
      font-family: var(--font-serif);
      font-size: clamp(var(--type-lg), 3.5vw, var(--type-xl));
      font-weight: 600;
      margin: 0;
    }
    .ch__tag {
      font-family: var(--font-mono);
      font-size: var(--type-xs);
      letter-spacing: var(--tracking-mono);
      color: var(--color-sub);
      margin: 0;
    }
    .ch__lead {
      font-size: var(--type-sm);
      line-height: var(--line-body-cjk);
      color: var(--color-ink-soft);
      max-width: var(--measure-narrow);
      margin-bottom: var(--space-3);
    }
    .ch__sub {
      font-family: var(--font-serif);
      font-size: var(--type-md);
      font-weight: 600;
      margin: var(--space-4) 0 var(--space-2);
      padding-top: var(--space-2);
      border-top: 1px solid var(--color-rule);
    }

    /* ═══ Data table ═══ */
    .data-table {
      width: 100%;
      border-collapse: collapse;
      margin: var(--space-2) 0 var(--space-3);
      font-size: var(--type-sm);
    }
    .data-table th,
    .data-table td {
      padding: var(--space-2);
      text-align: left;
      border: 1px solid var(--color-rule);
      vertical-align: top;
      line-height: 1.5;
    }
    .data-table thead th {
      background: var(--color-bg-soft);
      font-family: var(--font-mono);
      font-size: var(--type-xs);
      letter-spacing: var(--tracking-mono);
      text-transform: uppercase;
      color: var(--color-ink-soft);
      font-weight: 600;
    }
    .data-table tbody tr:nth-child(even) {
      background: var(--color-bg);
    }
    .data-table strong { color: var(--color-accent); }

    /* ═══ Note (details) ═══ */
    .note {
      border: 1px solid var(--color-rule);
      background: var(--color-bg-soft);
      padding: 0;
      margin: var(--space-3) 0;
    }
    .note summary {
      list-style: none;
      cursor: pointer;
      padding: var(--space-2) var(--space-3);
      font-family: var(--font-mono);
      font-size: var(--type-xs);
      letter-spacing: var(--tracking-mono);
      color: var(--color-accent);
    }
    .note summary::-webkit-details-marker { display: none; }
    .note summary:hover { color: var(--color-accent-2); }
    .note[open] summary {
      border-bottom: 1px solid var(--color-rule);
    }
    .note p, .note ul {
      padding: var(--space-2) var(--space-3);
      margin: 0;
      font-size: var(--type-sm);
      color: var(--color-ink-soft);
      line-height: 1.7;
    }
    .note ul {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 4px;
    }
    .note ul li::before {
      content: '→ ';
      color: var(--color-accent);
    }

    @media (max-width: 600px) {
      .anchor-nav__list {
        grid-template-columns: 1fr;
      }
      .data-table {
        font-size: var(--type-xs);
      }
      .data-table th,
      .data-table td {
        padding: var(--space-1);
      }
    }
  </style>
</Base>
