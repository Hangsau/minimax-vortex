---
/**
 * adm/matrix.astro — 4 支柱 × 4 階段矩陣
 *
 * master-detail：左為主（4 支柱 + 4 階段 → 16 格），
 * 每格點開顯示「觀察 / 行動 / 表達」三個視角的具體內容。
 *
 * 採用 4 階段（L2T → T2W）+ 4 支柱的靜態結構，
 * 不靠 JS master-detail 切換（per vortex-rebuild §1.3 反例），
 * 而是把 16 格直接攤開 + 細節用 <details> 摺合。
 */
import Base from '../../layouts/Base.astro';
import MiniLadder from '../../components/MiniLadder.astro';

const stages = [
  { key: 'l2t', zh: 'Learn to Train', l: 'L0–L2' },
  { key: 't2t', zh: 'Train to Train', l: 'L2–L4' },
  { key: 't2c', zh: 'Train to Compete', l: 'L4–L5' },
  { key: 't2w', zh: 'Train to Win', l: 'L5–L6' },
];

const pillars = [
  { key: 'physical', zh: '體能', en: 'Physical' },
  { key: 'technical', zh: '技術戰術', en: 'Technical' },
  { key: 'mental', zh: '心理技能', en: 'Mental' },
  { key: 'life', zh: '生活技能', en: 'Life' },
];

// 矩陣內容：每格（pillar + stage）三視角（觀察 / 行動 / 表達）
type CellContent = { observe: string; act: string; express: string };
type Matrix = Record<string, Record<string, CellContent>>;

const matrix: Matrix = {
  physical: {
    l2t: {
      observe: '能完成敏捷、平衡、協調的基本動作技能組合；能在 15m 浮板踢不停頓。',
      act: '基本動作技能 → 運動基礎技能；引入柔軟度、跳躍、陸地體能。',
      express: '用動作表達「我會這個動作」——單純模仿 + 完成度。',
    },
    t2t: {
      observe: '4S 中 S（速度）開始被識別；有氧耐力提升、可量測。',
      act: '肌力 + 耐力同步發展；陸上體能系統化；技術與體能開始分流。',
      express: '能說出「這個練習在練什麼」——理解連結而非只做動作。',
    },
    t2c: {
      observe: '有氧 + 無氧容量穩定成長；最大肌力達高原期。',
      act: '肌力轉化為爆發力；無氧訓練量上升；恢復成為顯學。',
      express: '把體能當成「比賽工具」——能談策略性地分配。',
    },
    t2w: {
      observe: '體能到達個人極限；可量測的進步幅度收斂。',
      act: '維持巔峰體能 + 精細調配；恢復 / 睡眠 / 營養的細節優化。',
      express: '把體能當成「風險管理」——什麼時候該推、什麼時候該收。',
    },
  },
  technical: {
    l2t: {
      observe: '掌握 L0–L2 的水感感知；學到基礎動作模式（划手、踢腿、換氣）。',
      act: 'Drill + 短距離反覆；強調動作模式建立，非速度。',
      express: '能描述「我抓到水的感覺」或「還沒抓到」——感受語萌芽。',
    },
    t2t: {
      observe: '技術序列開始分化（每式獨立訓練）；SPL 開始可量測。',
      act: '引入競賽型動作（出發、轉身）；開始技術 + 體能整合。',
      express: '能看出「我的弱點是什麼」——自我診斷能力。',
    },
    t2c: {
      observe: '技術在壓力下開始崩潰——「慢游好、比賽差」是主要訊號。',
      act: '針對崩潰點（EVF、耦合、時序）逐一修復；比賽模擬訓練。',
      express: '能在比賽中自我監控「我現在到哪一拍了」。',
    },
    t2w: {
      observe: '技術在最大壓力下仍維持；耦合自動化；連鎖感知穩定。',
      act: '把技術交給自動化系統；只在瓶頸出現時介入。',
      express: '技術本身消失——游完才知道「剛才有想到技術嗎」。',
    },
  },
  mental: {
    l2t: {
      observe: '對教練指令反應快；注意力持續時間短（兒童期正常）。',
      act: '建立正向態度；引入簡單目標（「今天 3 次踢完 15m」）。',
      express: '用情緒反應表達——開心、挫折、無聊。',
    },
    t2t: {
      observe: '能設定並追蹤短期目標；動機開始分化（內在 vs 外在）。',
      act: '動機氣候設計（mastery vs performance）；意象訓練起步。',
      express: '能說出「我想達到什麼」——未來導向。',
    },
    t2c: {
      observe: '情緒波動開始影響表現；自我對話頻繁；喚醒控制成為議題。',
      act: '情緒識別 + 調節；自我對話訓練；壓力模擬。',
      express: '能描述「我現在的情緒狀態」——元認知萌芽。',
    },
    t2w: {
      observe: '在高壓下仍維持情緒穩定；主動運用自我對話；能進入心流。',
      act: '去再投資（de-reinvestment）；自動化信任；賽前例行程序。',
      express: '「我信任訓練」——把結果交給準備。',
    },
  },
  life: {
    l2t: {
      observe: '社交技能：分享、輪流；自我覺察：能說出「我喜歡/不喜歡」。',
      act: '建立團隊歸屬感；教練—家長—選手三角穩定。',
      express: '用身體 + 語言表達「我屬於這裡」。',
    },
    t2t: {
      observe: '時間管理 + 學業 + 訓練開始競爭；自我管理是主要課題。',
      act: '教導目標設定 + 規劃；衝突解決；情緒表達。',
      express: '能區分「我想要」 vs「應該」——價值觀成形。',
    },
    t2c: {
      observe: '人際關係複雜化（同儕、教練、家庭、學校）；自我認同浮現。',
      act: '教練—選手溝通深化；壓力管理；身份認同支持。',
      express: '「我是誰 + 我在這做什麼」——統合感。',
    },
    t2w: {
      observe: '生活—訓練平衡成熟；運動員身分是人生的一部分而非全部。',
      act: '生涯規劃；退役轉銜預備；回饋社群。',
      express: '能向外輸出——「游泳教會我什麼」。',
    },
  },
};
---

<Base
  title="ADM 發展矩陣"
  description="4 支柱 × 4 階段（L2T → T2W）的 16 格 master-detail。每格含觀察 / 行動 / 表達三視角。"
>

  <!-- ═══ Hero ═══ -->
  <section class="hero">
    <p class="eyebrow">ADM · 4 × 4 Matrix</p>
    <h1 class="hero__title">發展矩陣</h1>
    <p class="hero__lead">
      4 支柱 × 4 階段 = 16 格。每格點開看「<strong>觀察</strong> / <strong>行動</strong> / <strong>表達</strong>」三視角的具體描述。
      不是「該練什麼」清單，是「在這個階段，運動員<em>長什麼樣</em>」的觀察框架。
    </p>
    <MiniLadder levels={['L0', 'L1', 'L2', 'L3', 'L4', 'L5', 'L6']} label="對應 L0–L6" />
  </section>

  <!-- ═══ 圖例 ═══ -->
  <section class="sec" id="legend">
    <p class="legend">
      <strong>三視角讀法：</strong>
      <span><em>觀察</em> = 教練看得到的外在行為 / 可量測的指標</span>
      <span><em>行動</em> = 訓練內容 / 介入方向</span>
      <span><em>表達</em> = 運動員能說、能感受、能意識到的內在</span>
    </p>
  </section>

  <!-- ═══ 矩陣：4 × 4 ═══ -->
  <section class="matrix" id="matrix">
    <div class="matrix__head">
      <div class="matrix__corner">
        <span class="matrix__corner-label">支柱 ＼ 階段</span>
      </div>
      {stages.map((s) => (
        <div class="matrix__stage-head">
          <h3 class="matrix__stage-zh">{s.zh}</h3>
          <p class="matrix__stage-l">{s.l}</p>
        </div>
      ))}
    </div>

    {pillars.map((p) => (
      <div class="matrix__row">
        <div class="matrix__pillar-head">
          <h3 class="matrix__pillar-zh">{p.zh}</h3>
          <p class="matrix__pillar-en">{p.en}</p>
        </div>
        {stages.map((s) => {
          const cell = matrix[p.key]?.[s.key];
          if (!cell) return <div class="matrix__cell matrix__cell--empty"></div>;
          return (
            <details class="matrix__cell">
              <summary class="matrix__cell-sum">
                <span class="matrix__cell-tag">觀察</span>
                <p class="matrix__cell-preview">{cell.observe}</p>
              </summary>
              <div class="matrix__cell-body">
                <div class="cell-block">
                  <span class="cell-block__tag">觀察</span>
                  <p>{cell.observe}</p>
                </div>
                <div class="cell-block">
                  <span class="cell-block__tag">行動</span>
                  <p>{cell.act}</p>
                </div>
                <div class="cell-block">
                  <span class="cell-block__tag">表達</span>
                  <p>{cell.express}</p>
                </div>
              </div>
            </details>
          );
        })}
      </div>
    ))}
  </section>

  <!-- ═══ 4 階段時序視角 ═══ -->
  <section class="sec">
    <header class="sec__head">
      <h2 class="sec__title"><span class="sec__no">貳</span>階段時序</h2>
      <span class="eyebrow sec__tag">Stage Timeline</span>
    </header>
    <p class="sec__lead">同一支柱沿 4 階段的演變——點開看完整對比。</p>
    {pillars.map((p) => (
      <details class="pillar-trace">
        <summary class="pillar-trace__sum">
          <span class="pillar-trace__zh">{p.zh}</span>
          <span class="pillar-trace__en">{p.en}</span>
        </summary>
        <div class="pillar-trace__body">
          <ol class="trace-list">
            {stages.map((s) => {
              const cell = matrix[p.key]?.[s.key];
              if (!cell) return null;
              return (
                <li class="trace-item">
                  <span class="trace-item__stage">{s.zh}</span>
                  <span class="trace-item__l">{s.l}</span>
                  <p class="trace-item__text">{cell.observe}</p>
                </li>
              );
            })}
          </ol>
        </div>
      </details>
    ))}
  </section>

  <style>
    .hero {
      padding: var(--space-6) 0 var(--space-5);
      border-bottom: 2px solid var(--color-rule-strong);
    }
    .hero__title {
      font-family: var(--font-serif);
      font-weight: 700;
      font-size: clamp(var(--type-2xl), 5vw, var(--type-3xl));
      line-height: 1.1;
      margin: var(--space-2) 0 var(--space-3);
    }
    .hero__lead {
      font-family: var(--font-serif);
      font-size: var(--type-md);
      line-height: var(--line-body-cjk);
      color: var(--color-ink-soft);
      max-width: var(--measure-narrow);
      margin-bottom: var(--space-4);
    }
    .hero :global(.mini-ladder) { margin-top: var(--space-3); }
    .hero em {
      font-style: normal;
      color: var(--color-accent);
      font-weight: 600;
    }

    .sec {
      margin-top: var(--space-7);
      padding-top: var(--space-4);
      border-top: 2px solid var(--color-rule-strong);
    }
    .sec__head {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      gap: var(--space-3);
      flex-wrap: wrap;
      margin-bottom: var(--space-3);
    }
    .sec__title {
      font-family: var(--font-serif);
      font-weight: 600;
      font-size: clamp(var(--type-xl), 4vw, var(--type-2xl));
      margin: 0;
    }
    .sec__no {
      font-family: var(--font-mono);
      font-size: 0.7em;
      color: var(--color-accent);
      margin-right: 0.4em;
    }
    .sec__tag { color: var(--color-sub); }
    .sec__lead {
      font-size: var(--type-sm);
      line-height: var(--line-body-cjk);
      color: var(--color-ink-soft);
      max-width: var(--measure-narrow);
      margin-bottom: var(--space-3);
    }

    .legend {
      display: flex;
      flex-wrap: wrap;
      gap: var(--space-2);
      align-items: baseline;
      padding: var(--space-3);
      background: var(--color-bg-soft);
      border: 1px solid var(--color-rule);
      margin: var(--space-3) 0 0;
      font-size: var(--type-sm);
      color: var(--color-ink-soft);
    }
    .legend strong {
      color: var(--color-ink);
      font-weight: 600;
    }
    .legend em {
      font-style: normal;
      color: var(--color-accent);
      font-weight: 600;
    }

    /* ═══ Matrix ═══ */
    .matrix {
      display: grid;
      grid-template-columns: 140px repeat(4, 1fr);
      gap: 1px;
      background: var(--color-rule);
      border: 1px solid var(--color-rule-strong);
      margin-top: var(--space-3);
    }
    .matrix__head {
      display: contents;
    }
    .matrix__corner {
      background: var(--color-bg);
      padding: var(--space-2);
      display: flex;
      align-items: center;
    }
    .matrix__corner-label {
      font-family: var(--font-mono);
      font-size: var(--type-tiny);
      color: var(--color-sub);
      letter-spacing: var(--tracking-eyebrow);
      text-transform: uppercase;
    }
    .matrix__stage-head {
      background: var(--color-bg-soft);
      padding: var(--space-2);
      border-bottom: 2px solid var(--color-rule-strong);
    }
    .matrix__stage-zh {
      font-family: var(--font-serif);
      font-size: var(--type-sm);
      font-weight: 600;
      margin: 0 0 2px;
    }
    .matrix__stage-l {
      font-family: var(--font-mono);
      font-size: var(--type-tiny);
      color: var(--color-accent);
      letter-spacing: var(--tracking-mono);
      margin: 0;
    }
    .matrix__row {
      display: contents;
    }
    .matrix__pillar-head {
      background: var(--color-bg-soft);
      padding: var(--space-2);
      border-right: 1px solid var(--color-rule-strong);
    }
    .matrix__pillar-zh {
      font-family: var(--font-serif);
      font-size: var(--type-sm);
      font-weight: 600;
      margin: 0 0 2px;
    }
    .matrix__pillar-en {
      font-family: var(--font-mono);
      font-size: var(--type-tiny);
      color: var(--color-sub);
      letter-spacing: var(--tracking-mono);
      margin: 0;
    }
    .matrix__cell {
      background: var(--color-bg-elev);
      padding: 0;
    }
    .matrix__cell--empty { background: var(--color-bg); }
    .matrix__cell-sum {
      list-style: none;
      cursor: pointer;
      padding: var(--space-2);
      display: flex;
      flex-direction: column;
      gap: var(--space-1);
      min-height: 96px;
    }
    .matrix__cell-sum::-webkit-details-marker { display: none; }
    .matrix__cell-sum:hover { background: var(--color-bg-soft); }
    .matrix__cell-tag {
      font-family: var(--font-mono);
      font-size: var(--type-tiny);
      letter-spacing: var(--tracking-eyebrow);
      text-transform: uppercase;
      color: var(--color-accent);
    }
    .matrix__cell-preview {
      font-size: var(--type-xs);
      color: var(--color-ink-soft);
      line-height: 1.5;
      margin: 0;
      display: -webkit-box;
      -webkit-line-clamp: 3;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
    .matrix__cell[open] .matrix__cell-sum {
      background: var(--color-accent);
    }
    .matrix__cell[open] .matrix__cell-tag { color: var(--color-bg); }
    .matrix__cell[open] .matrix__cell-preview { color: var(--color-bg); }
    .matrix__cell-body {
      padding: var(--space-2);
      background: var(--color-bg-elev);
      border-top: 1px solid var(--color-rule);
      display: flex;
      flex-direction: column;
      gap: var(--space-2);
    }
    .cell-block {
      display: flex;
      flex-direction: column;
      gap: 2px;
    }
    .cell-block__tag {
      font-family: var(--font-mono);
      font-size: var(--type-tiny);
      letter-spacing: var(--tracking-eyebrow);
      text-transform: uppercase;
      color: var(--color-accent);
    }
    .cell-block p {
      font-size: var(--type-xs);
      color: var(--color-ink-soft);
      line-height: 1.6;
      margin: 0;
    }

    /* ═══ Pillar trace ═══ */
    .pillar-trace {
      border: 1px solid var(--color-rule);
      background: var(--color-bg-elev);
      margin-bottom: var(--space-2);
    }
    .pillar-trace__sum {
      list-style: none;
      cursor: pointer;
      display: flex;
      align-items: baseline;
      gap: var(--space-2);
      padding: var(--space-2) var(--space-3);
    }
    .pillar-trace__sum::-webkit-details-marker { display: none; }
    .pillar-trace__sum:hover { background: var(--color-bg-soft); }
    .pillar-trace__zh {
      font-family: var(--font-serif);
      font-size: var(--type-md);
      font-weight: 600;
    }
    .pillar-trace__en {
      font-family: var(--font-mono);
      font-size: var(--type-tiny);
      color: var(--color-sub);
      letter-spacing: var(--tracking-mono);
    }
    .pillar-trace[open] .pillar-trace__sum {
      border-bottom: 1px solid var(--color-rule);
    }
    .pillar-trace__body {
      padding: var(--space-3);
    }
    .trace-list {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-direction: column;
      gap: var(--space-2);
    }
    .trace-item {
      padding: var(--space-2);
      border: 1px solid var(--color-rule);
      background: var(--color-bg);
    }
    .trace-item__stage {
      font-family: var(--font-serif);
      font-size: var(--type-sm);
      font-weight: 600;
      margin-right: var(--space-2);
    }
    .trace-item__l {
      font-family: var(--font-mono);
      font-size: var(--type-tiny);
      color: var(--color-accent);
      letter-spacing: var(--tracking-mono);
    }
    .trace-item__text {
      font-size: var(--type-xs);
      color: var(--color-ink-soft);
      line-height: 1.6;
      margin: var(--space-1) 0 0;
    }

    @media (max-width: 820px) {
      .matrix {
        grid-template-columns: 1fr;
      }
      .matrix__head { display: none; }
      .matrix__row { display: block; }
      .matrix__pillar-head {
        border-right: none;
        border-bottom: 1px solid var(--color-rule-strong);
        background: var(--color-bg-soft);
      }
      .matrix__cell-sum { min-height: 60px; }
    }
  </style>
</Base>
