---
/**
 * database/index.astro — 跨泳式資料庫
 *
 * 設計依據（per vortex-rebuild + entry-wayfinding）：
 * - 主角：依需求找練習（環節 × 階段 × 泳式三軸 filter + drill 卡片）
 * - 配角：跨泳式查資料（誤區 / 機制 / L 指標三 tab + 搜尋）
 * - drills 全部 inline 在 build time（client-side filter，無 fetch）
 */
import { readFileSync } from 'node:fs';
import { resolve } from 'node:path';
import yaml from 'js-yaml';
import Base from '../../layouts/Base.astro';
import MiniLadder from '../../components/MiniLadder.astro';

// ── 載入 drills（在 build time 處理完，inline 進 HTML）────────
// 用 process.cwd() 而非 import.meta.url — 後者在 SSR/build 編譯後會指向 dist/。
const dataPath = (p: string) => resolve(process.cwd(), 'src/data', p);
const drillsRaw = yaml.load(
  readFileSync(dataPath('drills.yaml'), 'utf8')
) as any;
const allDrills = drillsRaw.drills ?? [];

// 取所需欄位的精簡版（避免 inline 整個 how_to 等大字串）
type DrillCard = {
  id: string;
  name_zh: string;
  name_en: string;
  stroke: string;
  strokes: string[];
  category: string;
  l_target: string[];
  purpose_zh: string;
  perception_goal: string;
  success_signal: string;
  failure_signal: string;
  source: string;
};

const strokes = [
  { key: 'freestyle', zh: '自由式' },
  { key: 'backstroke', zh: '仰式' },
  { key: 'breaststroke', zh: '蛙式' },
  { key: 'butterfly', zh: '蝶式' },
  { key: 'underwater_dolphin_kick', zh: '海豚踢' },
  { key: 'starts_turns', zh: '出發轉身' },
];

const categories = [
  { key: 'breathing', zh: '換氣' },
  { key: 'balance', zh: '平衡' },
  { key: 'kick', zh: '踢腿' },
  { key: 'arm', zh: '划手' },
  { key: 'timing', zh: '時序' },
  { key: 'sculling', zh: '搖櫓' },
];

const levels = ['L0', 'L1', 'L2', 'L3', 'L4', 'L5', 'L6'];

const drills: DrillCard[] = allDrills.map((d: any) => ({
  id: d.id,
  name_zh: d.name_zh,
  name_en: d.name_en,
  stroke: d.strokes?.[0] ?? '',
  strokes: d.strokes ?? [],
  category: d.category,
  l_target: d.l_target ?? [],
  purpose_zh: d.purpose_zh ?? '',
  perception_goal: d.perception_goal ?? '',
  success_signal: d.success_signal ?? '',
  failure_signal: d.failure_signal ?? '',
  source: d.source ?? '',
}));

// 載入 L 指標（顯示在「跨式查」L 指標 tab）
const liRaw = yaml.load(
  readFileSync(dataPath('l-indicators.yaml'), 'utf8')
) as any;
const indicators = (liRaw.indicators ?? []).map((i: any) => ({
  id: i.id,
  stroke: i.stroke,
  level: i.level,
  aspect: i.aspect,
  indicator: i.indicator,
  framework_state: i.framework_state,
  quant_ref: i.quant_ref,
}));

// 載入誤區 + 機制（教學錯誤 = 誤區，技術分析 = 機制）
const teRaw = yaml.load(
  readFileSync(dataPath('teaching-errors.yaml'), 'utf8')
) as any;
const taRaw = yaml.load(
  readFileSync(dataPath('technical-analysis.yaml'), 'utf8')
) as any;

// teaching-errors 結構：categories + 各類別的 item
// technical-analysis 結構：categories + categories.item
// 兩者都是 categories 字典，把所有 item 攤平
function flattenTaYml(raw: any) {
  const out: any[] = [];
  if (!raw?.categories) return out;
  for (const cat of raw.categories) {
    const items = cat.items ?? cat.moves ?? cat.errors ?? [];
    for (const it of items) {
      out.push({
        category: cat.key,
        category_zh: cat.name_zh,
        ...it,
      });
    }
  }
  return out;
}
const taItems = flattenTaYml(taRaw);
const teItems = flattenTaYml(teRaw);

// ── 序列化給前端 filter（JSON-stringified 進 data attribute）──
const drillsJson = JSON.stringify(drills);
const indicatorsJson = JSON.stringify(indicators);
const teItemsJson = JSON.stringify(teItems);
const taItemsJson = JSON.stringify(taItems);
const strokesJson = JSON.stringify(strokes);
const categoriesJson = JSON.stringify(categories);
const levelsJson = JSON.stringify(levels);
---

<Base
  title="跨泳式資料庫"
  description="依需求找練習（環節 × 階段 × 泳式），或跨泳式查誤區、機制、L 指標。125 筆 drills 全部 inline。"
>

  <!-- ═══ Hero ═══ -->
  <section class="hero">
    <p class="eyebrow">Cross-Stroke Database</p>
    <h1 class="hero__title">跨泳式資料庫</h1>
    <p class="hero__lead">
      兩種用法：<strong>依需求找練習</strong>（已知道想練什麼，挑環節 + 階段 + 泳式），
      或<strong>跨泳式查資料</strong>（已知道要查什麼，看誤區、機制、L 指標）。
    </p>
    <MiniLadder levels={['L0', 'L1', 'L2', 'L3', 'L4', 'L5', 'L6']} label="涵蓋全 L0–L6" />
  </section>

  <!-- ═══ 主：依需求找練習 ═══ -->
  <section class="sec" id="find">
    <header class="sec__head">
      <h2 class="sec__title"><span class="sec__no">壹</span>依需求找練習</h2>
      <span class="eyebrow sec__tag">Find Drills by Need</span>
    </header>
    <p class="sec__lead">
      三軸 filter：環節 × 階段 × 泳式。即時計算符合條件的 drills，可疊加可不疊加。
    </p>

    <!-- Filter panel -->
    <form class="filter" id="db-filter" data-drills={drillsJson} data-strokes={strokesJson} data-categories={categoriesJson} data-levels={levelsJson} aria-label="drill 三軸 filter">
      <fieldset class="filter__group">
        <legend class="filter__legend">環節</legend>
        <div class="filter__pills">
          {categories.map((c) => (
            <label class="pill">
              <input type="checkbox" name="category" value={c.key} />
              <span>{c.zh}</span>
            </label>
          ))}
        </div>
      </fieldset>

      <fieldset class="filter__group">
        <legend class="filter__legend">階段</legend>
        <div class="filter__pills">
          {levels.map((l) => (
            <label class="pill">
              <input type="checkbox" name="level" value={l} />
              <span>{l}</span>
            </label>
          ))}
        </div>
      </fieldset>

      <fieldset class="filter__group">
        <legend class="filter__legend">泳式</legend>
        <div class="filter__pills">
          {strokes.map((s) => (
            <label class="pill">
              <input type="checkbox" name="stroke" value={s.key} />
              <span>{s.zh}</span>
            </label>
          ))}
        </div>
      </fieldset>

      <div class="filter__actions">
        <button type="reset" class="btn-mini">清空</button>
        <p class="filter__count" aria-live="polite" id="db-count">
          共 <strong>{drills.length}</strong> 筆
        </p>
      </div>
    </form>

    <!-- Drill cards grid -->
    <div class="drill-grid" id="db-grid">
      {drills.map((d) => (
        <article class="drill-card" data-id={d.id} data-category={d.category} data-levels={d.l_target.join(',')} data-strokes={d.strokes.join(',')}>
          <header class="drill-card__head">
            <span class="drill-card__id">{d.id}</span>
            <span class="drill-card__levels">
              {d.l_target.map((l) => <span class="lvl">{l}</span>)}
            </span>
          </header>
          <h3 class="drill-card__zh">{d.name_zh}</h3>
          <p class="drill-card__en">{d.name_en}</p>
          <p class="drill-card__purpose">{d.purpose_zh}</p>
          <dl class="drill-card__meta">
            <dt>感知目標</dt><dd>{d.perception_goal}</dd>
            <dt>成功訊號</dt><dd>{d.success_signal}</dd>
            <dt>失敗訊號</dt><dd>{d.failure_signal}</dd>
          </dl>
          <footer class="drill-card__foot">
            <span class="drill-card__cat">{d.category}</span>
            <span class="drill-card__stroke">
              {strokes.find((s) => s.key === d.stroke)?.zh ?? d.stroke}
            </span>
          </footer>
        </article>
      ))}
    </div>

    <!-- Empty state -->
    <p class="empty hidden" id="db-empty">沒有符合條件的 drill。試著放寬篩選。</p>
  </section>

  <!-- ═══ 配：跨泳式查資料 ═══ -->
  <section class="sec" id="lookup">
    <header class="sec__head">
      <h2 class="sec__title"><span class="sec__no">貳</span>跨泳式查資料</h2>
      <span class="eyebrow sec__tag">Cross-Stroke Lookup</span>
    </header>
    <p class="sec__lead">
      當你已知道要查什麼類型的東西，看三類：誤區（常見錯的）、機制（為什麼）、L 指標（量化基準）。
    </p>

    <!-- Tabs -->
    <div class="tabs" data-ta={taItemsJson} data-te={teItemsJson} data-li={indicatorsJson} data-strokes={strokesJson}>
      <div class="tabs__bar" role="tablist">
        <button class="tab is-on" role="tab" aria-selected="true" data-tab="errors">誤區</button>
        <button class="tab" role="tab" aria-selected="false" data-tab="mechanism">機制</button>
        <button class="tab" role="tab" aria-selected="false" data-tab="indicators">L 指標</button>
      </div>

      <!-- Search + stroke filter -->
      <div class="tabs__filter">
        <label class="search">
          <span class="search__hint">搜尋</span>
          <input type="search" id="lookup-q" placeholder="關鍵字…" aria-label="搜尋誤區/機制/指標" />
        </label>
        <label class="search">
          <span class="search__hint">泳式</span>
          <select id="lookup-stroke" aria-label="篩選泳式">
            <option value="">全部</option>
            <option value="common">跨式通用</option>
            {strokes.map((s) => <option value={s.key}>{s.zh}</option>)}
          </select>
        </label>
      </div>

      <!-- Tab panels -->
      <div class="tab-panels">
        <div class="tab-panel is-on" role="tabpanel" data-panel="errors" id="panel-errors">
          <p class="panel-count" aria-live="polite" id="count-errors"></p>
          <ul class="item-list" id="list-errors"></ul>
        </div>
        <div class="tab-panel" role="tabpanel" data-panel="mechanism" id="panel-mechanism" hidden>
          <p class="panel-count" aria-live="polite" id="count-mechanism"></p>
          <ul class="item-list" id="list-mechanism"></ul>
        </div>
        <div class="tab-panel" role="tabpanel" data-panel="indicators" id="panel-indicators" hidden>
          <p class="panel-count" aria-live="polite" id="count-indicators"></p>
          <ul class="item-list" id="list-indicators"></ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ Client-side filter + tab + search 邏輯 ═══ -->
  <script is:inline>
    (function () {
      // ── Helper：escape HTML ──
      function esc(s) {
        return String(s ?? '').replace(/[&<>"']/g, (c) => ({
          '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;',
        }[c]));
      }

      // ── Find Drills：環節 × 階段 × 泳式 ──
      const filterEl = document.getElementById('db-filter');
      const grid = document.getElementById('db-grid');
      const empty = document.getElementById('db-empty');
      const countEl = document.getElementById('db-count');
      const cards = Array.from(grid.querySelectorAll('.drill-card'));

      function applyFilter() {
        const cats = Array.from(filterEl.querySelectorAll('input[name="category"]:checked')).map((i) => i.value);
        const lvls = Array.from(filterEl.querySelectorAll('input[name="level"]:checked')).map((i) => i.value);
        const strs = Array.from(filterEl.querySelectorAll('input[name="stroke"]:checked')).map((i) => i.value);

        let visible = 0;
        cards.forEach((c) => {
          const cardCat = c.dataset.category;
          const cardLvls = c.dataset.levels.split(',').filter(Boolean);
          const cardStrs = c.dataset.strokes.split(',').filter(Boolean);
          const matchCat = cats.length === 0 || cats.includes(cardCat);
          const matchLvl = lvls.length === 0 || cardLvls.some((l) => lvls.includes(l));
          const matchStr = strs.length === 0 || cardStrs.some((s) => strs.includes(s));
          const show = matchCat && matchLvl && matchStr;
          c.style.display = show ? '' : 'none';
          if (show) visible++;
        });
        countEl.innerHTML = '共 <strong>' + visible + '</strong> 筆 / ' + cards.length;
        empty.classList.toggle('hidden', visible !== 0);
      }
      filterEl.addEventListener('change', applyFilter);
      filterEl.addEventListener('reset', () => setTimeout(applyFilter, 0));

      // ── Tabs：切換 + 搜尋 + 泳式 filter ──
      const tabsRoot = document.querySelector('.tabs');
      const taData = JSON.parse(tabsRoot.dataset.ta);
      const teData = JSON.parse(tabsRoot.dataset.te);
      const liData = JSON.parse(tabsRoot.dataset.li);
      const strokesData = JSON.parse(tabsRoot.dataset.strokes);
      const strokeName = (key) => (strokesData.find((s) => s.key === key) || { zh: key }).zh;
      const strokeNameOrCommon = (key) => key === 'common' ? '跨式通用' : strokeName(key);

      const panels = {
        errors: { data: teData, fields: { name: 'name', name_zh: 'name_zh', desc: 'description', cat: 'category_zh' } },
        mechanism: { data: taData, fields: { name: 'name', name_zh: 'name_zh', desc: 'physical', cat: 'category_zh' } },
        indicators: { data: liData, fields: { name: 'aspect', name_zh: 'aspect', desc: 'indicator', cat: 'framework_state' } },
      };

      function renderTab(tabKey) {
        const conf = panels[tabKey];
        const q = document.getElementById('lookup-q').value.trim().toLowerCase();
        const stroke = document.getElementById('lookup-stroke').value;
        const list = document.getElementById('list-' + tabKey);
        const counter = document.getElementById('count-' + tabKey);

        const filtered = conf.data.filter((it) => {
          // 泳式 filter：teaching-errors / technical-analysis 沒有 stroke 欄位，跳過 stroke filter
          if (stroke && it.stroke && it.stroke !== 'common' && it.stroke !== stroke) return false;
          if (!q) return true;
          const hay = [it.name, it.name_zh, it.description, it.physical, it.indicator, it.aspect, it.category_zh, it.framework_state]
            .filter(Boolean).join(' ').toLowerCase();
          return hay.includes(q);
        });

        counter.textContent = '共 ' + filtered.length + ' 筆';
        list.innerHTML = filtered.slice(0, 60).map((it) => {
          const name = esc(it.name_zh || it.name || it.aspect || '');
          const desc = esc(it.description || it.physical || it.indicator || '');
          const cat = esc(it.category_zh || it.framework_state || it.category || '');
          const level = it.level ? '<span class="lvl">' + esc(it.level) + '</span>' : '';
          const stroke2 = it.stroke ? '<span class="item-stroke">' + esc(strokeNameOrCommon(it.stroke)) + '</span>' : '';
          return '<li class="item"><h4 class="item__name">' + name + ' ' + level + ' ' + stroke2 + '</h4><p class="item__cat">' + cat + '</p><p class="item__desc">' + desc + '</p></li>';
        }).join('') + (filtered.length > 60 ? '<li class="item item--more">顯示前 60 筆，共 ' + filtered.length + ' 筆。試著收窄搜尋或泳式。</li>' : '');
      }

      function switchTab(target) {
        document.querySelectorAll('.tab').forEach((t) => {
          const on = t.dataset.tab === target;
          t.classList.toggle('is-on', on);
          t.setAttribute('aria-selected', on ? 'true' : 'false');
        });
        document.querySelectorAll('.tab-panel').forEach((p) => {
          const on = p.dataset.panel === target;
          p.classList.toggle('is-on', on);
          p.hidden = !on;
        });
        renderTab(target);
      }

      document.querySelectorAll('.tab').forEach((t) => {
        t.addEventListener('click', () => switchTab(t.dataset.tab));
      });
      document.getElementById('lookup-q').addEventListener('input', () => {
        const active = document.querySelector('.tab.is-on').dataset.tab;
        renderTab(active);
      });
      document.getElementById('lookup-stroke').addEventListener('change', () => {
        const active = document.querySelector('.tab.is-on').dataset.tab;
        renderTab(active);
      });

      // 初次渲染
      renderTab('errors');
    })();
  </script>

  <style>
    /* ═══ Hero ═══ */
    .hero {
      padding: var(--space-6) 0 var(--space-5);
      border-bottom: 2px solid var(--color-rule-strong);
    }
    .hero__title {
      font-family: var(--font-serif);
      font-weight: 700;
      font-size: clamp(var(--type-2xl), 5vw, var(--type-3xl));
      line-height: 1.1;
      margin: var(--space-2) 0 var(--space-3);
    }
    .hero__lead {
      font-family: var(--font-serif);
      font-size: var(--type-md);
      line-height: var(--line-body-cjk);
      color: var(--color-ink-soft);
      max-width: var(--measure-narrow);
      margin-bottom: var(--space-4);
    }
    .hero :global(.mini-ladder) {
      margin-top: var(--space-3);
    }

    /* ═══ Section ═══ */
    .sec {
      margin-top: var(--space-7);
      padding-top: var(--space-4);
      border-top: 2px solid var(--color-rule-strong);
    }
    .sec__head {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      gap: var(--space-3);
      flex-wrap: wrap;
      margin-bottom: var(--space-3);
    }
    .sec__title {
      font-family: var(--font-serif);
      font-weight: 600;
      font-size: clamp(var(--type-xl), 4vw, var(--type-2xl));
      margin: 0;
    }
    .sec__no {
      font-family: var(--font-mono);
      font-size: 0.7em;
      color: var(--color-accent);
      margin-right: 0.4em;
    }
    .sec__tag { color: var(--color-sub); }
    .sec__lead {
      font-size: var(--type-sm);
      line-height: var(--line-body-cjk);
      color: var(--color-ink-soft);
      max-width: var(--measure-narrow);
      margin-bottom: var(--space-4);
    }

    /* ═══ Filter ═══ */
    .filter {
      border: 1px solid var(--color-rule);
      background: var(--color-bg-soft);
      padding: var(--space-3);
      display: flex;
      flex-direction: column;
      gap: var(--space-3);
      margin-bottom: var(--space-4);
    }
    .filter__group {
      border: none;
      padding: 0;
      margin: 0;
    }
    .filter__legend {
      font-family: var(--font-mono);
      font-size: var(--type-xs);
      letter-spacing: var(--tracking-eyebrow);
      text-transform: uppercase;
      color: var(--color-sub);
      margin-bottom: var(--space-1);
    }
    .filter__pills {
      display: flex;
      flex-wrap: wrap;
      gap: var(--space-1);
    }
    .pill {
      display: inline-flex;
      align-items: center;
      cursor: pointer;
      user-select: none;
    }
    .pill input {
      position: absolute;
      opacity: 0;
      pointer-events: none;
    }
    .pill span {
      display: inline-flex;
      align-items: center;
      min-height: 32px;
      padding: var(--space-1) var(--space-3);
      border: 1px solid var(--color-border);
      background: var(--color-bg-elev);
      font-size: var(--type-sm);
      color: var(--color-ink);
      transition: background-color var(--duration-short) var(--ease-standard),
                  border-color var(--duration-short) var(--ease-standard);
    }
    .pill:hover span {
      border-color: var(--color-accent);
    }
    .pill input:checked + span {
      background: var(--color-accent);
      border-color: var(--color-accent);
      color: var(--color-bg);
    }
    .pill input:focus-visible + span {
      outline: 2px solid var(--color-accent);
      outline-offset: 2px;
    }
    .filter__actions {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: var(--space-3);
      border-top: 1px dashed var(--color-rule);
      padding-top: var(--space-2);
    }
    .btn-mini {
      font-family: var(--font-mono);
      font-size: var(--type-xs);
      letter-spacing: var(--tracking-mono);
      padding: var(--space-1) var(--space-2);
      border: 1px solid var(--color-border);
      background: var(--color-bg-elev);
      color: var(--color-ink);
      cursor: pointer;
      min-height: 32px;
    }
    .btn-mini:hover {
      border-color: var(--color-accent);
    }
    .filter__count {
      font-family: var(--font-mono);
      font-size: var(--type-sm);
      color: var(--color-ink-soft);
      margin: 0;
    }
    .filter__count strong {
      color: var(--color-accent);
      font-size: var(--type-md);
    }

    /* ═══ Drill grid ═══ */
    .drill-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
      gap: var(--space-2);
    }
    .drill-card {
      display: flex;
      flex-direction: column;
      gap: var(--space-1);
      padding: var(--space-3);
      border: 1px solid var(--color-rule);
      background: var(--color-bg-elev);
    }
    .drill-card__head {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: var(--space-2);
    }
    .drill-card__id {
      font-family: var(--font-mono);
      font-size: var(--type-tiny);
      letter-spacing: var(--tracking-mono);
      color: var(--color-accent);
      text-transform: uppercase;
    }
    .drill-card__levels {
      display: flex;
      gap: 2px;
    }
    .lvl {
      font-family: var(--font-mono);
      font-size: var(--type-tiny);
      letter-spacing: var(--tracking-mono);
      padding: 2px 4px;
      background: var(--color-bg-soft);
      border: 1px solid var(--color-rule);
    }
    .drill-card__zh {
      font-family: var(--font-serif);
      font-size: var(--type-md);
      font-weight: 600;
      margin: 0;
      line-height: 1.2;
    }
    .drill-card__en {
      font-family: var(--font-mono);
      font-size: var(--type-xs);
      color: var(--color-sub);
      margin: 0;
    }
    .drill-card__purpose {
      font-size: var(--type-sm);
      color: var(--color-ink);
      line-height: 1.5;
      margin: var(--space-1) 0;
    }
    .drill-card__meta {
      display: grid;
      grid-template-columns: auto 1fr;
      gap: 2px var(--space-2);
      margin: 0;
      padding: var(--space-2) 0 0;
      border-top: 1px dashed var(--color-rule);
      font-size: var(--type-xs);
      line-height: 1.5;
    }
    .drill-card__meta dt {
      font-family: var(--font-mono);
      color: var(--color-sub);
      letter-spacing: var(--tracking-mono);
      text-transform: uppercase;
    }
    .drill-card__meta dd {
      margin: 0;
      color: var(--color-ink-soft);
    }
    .drill-card__foot {
      display: flex;
      gap: var(--space-2);
      padding-top: var(--space-2);
      border-top: 1px dashed var(--color-rule);
      font-family: var(--font-mono);
      font-size: var(--type-tiny);
      letter-spacing: var(--tracking-mono);
      color: var(--color-sub);
      text-transform: uppercase;
    }
    .empty {
      text-align: center;
      padding: var(--space-5);
      color: var(--color-sub);
      font-size: var(--type-sm);
    }
    .hidden { display: none; }

    /* ═══ Tabs ═══ */
    .tabs__bar {
      display: flex;
      gap: 0;
      border-bottom: 2px solid var(--color-rule-strong);
      margin-bottom: var(--space-3);
    }
    .tab {
      font-family: var(--font-mono);
      font-size: var(--type-sm);
      letter-spacing: var(--tracking-mono);
      padding: var(--space-2) var(--space-3);
      color: var(--color-sub);
      background: none;
      border: 1px solid transparent;
      border-bottom: none;
      cursor: pointer;
      min-height: 44px;
    }
    .tab:hover {
      color: var(--color-ink);
    }
    .tab.is-on {
      color: var(--color-ink);
      background: var(--color-bg-elev);
      border-color: var(--color-rule-strong);
      border-bottom: 1px solid var(--color-bg-elev);
      margin-bottom: -1px;
    }
    .tabs__filter {
      display: flex;
      gap: var(--space-3);
      flex-wrap: wrap;
      margin-bottom: var(--space-3);
    }
    .search {
      display: flex;
      align-items: center;
      gap: var(--space-1);
      border: 1px solid var(--color-border);
      background: var(--color-bg-elev);
      padding: 0 var(--space-2);
      min-height: 36px;
      flex: 1 1 200px;
    }
    .search__hint {
      font-family: var(--font-mono);
      font-size: var(--type-xs);
      letter-spacing: var(--tracking-eyebrow);
      text-transform: uppercase;
      color: var(--color-sub);
    }
    .search input, .search select {
      border: none;
      background: none;
      font: inherit;
      flex: 1;
      padding: var(--space-1) 0;
      color: var(--color-ink);
    }
    .search input:focus, .search select:focus {
      outline: none;
    }
    .search:focus-within {
      outline: 2px solid var(--color-accent);
      outline-offset: 1px;
    }
    .panel-count {
      font-family: var(--font-mono);
      font-size: var(--type-xs);
      color: var(--color-sub);
      letter-spacing: var(--tracking-mono);
      margin: 0 0 var(--space-2);
    }
    .item-list {
      list-style: none;
      margin: 0;
      padding: 0;
      display: flex;
      flex-direction: column;
      gap: var(--space-2);
    }
    .item {
      padding: var(--space-3);
      border: 1px solid var(--color-rule);
      background: var(--color-bg-elev);
    }
    .item__name {
      font-family: var(--font-serif);
      font-size: var(--type-md);
      font-weight: 600;
      margin: 0 0 var(--space-1);
      display: flex;
      align-items: center;
      gap: var(--space-2);
      flex-wrap: wrap;
    }
    .item-stroke {
      font-family: var(--font-mono);
      font-size: var(--type-tiny);
      letter-spacing: var(--tracking-mono);
      color: var(--color-sub);
      text-transform: uppercase;
    }
    .item__cat {
      font-family: var(--font-mono);
      font-size: var(--type-xs);
      color: var(--color-accent);
      letter-spacing: var(--tracking-mono);
      margin: 0 0 var(--space-1);
      text-transform: uppercase;
    }
    .item__desc {
      font-size: var(--type-sm);
      color: var(--color-ink-soft);
      line-height: 1.6;
      margin: 0;
    }
    .item--more {
      text-align: center;
      color: var(--color-sub);
      font-size: var(--type-sm);
      border-style: dashed;
    }

    @media (max-width: 600px) {
      .filter__actions {
        flex-direction: column;
        align-items: stretch;
      }
      .drill-grid {
        grid-template-columns: 1fr;
      }
      .tabs__filter {
        flex-direction: column;
      }
    }
  </style>
</Base>
